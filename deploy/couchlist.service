# couchlist.service — keep the Node server running for couchlist.org.
#
# This is a systemd "unit file." systemd is Linux's built-in service
# manager — the same thing that starts sshd, cron, nginx, etc. at boot.
# Once this unit is installed and enabled, Linux treats our Node app
# exactly like any other system service: starts it on boot, restarts it
# if it crashes, and collects its logs via journalctl.
#
# Install (one-time, run as root on the droplet):
#   cp /root/projects/couchlist/deploy/couchlist.service /etc/systemd/system/
#   systemctl daemon-reload                       # re-scan unit files
#   systemctl enable --now couchlist.service      # start + start-on-boot
#
# Inspect:
#   systemctl status couchlist              # is it running? last logs?
#   journalctl -u couchlist -f              # live stream of stdout/err
#   journalctl -u couchlist --since today   # today's log history

[Unit]
Description=couchlist — couchlist.org Node server
# Wait for the network to be fully up before starting. Without this,
# the service can race the network and fail on boot.
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Run as root for now — simplest path; harden later with a dedicated user.
User=root
# WorkingDirectory so relative paths in server.js resolve correctly.
WorkingDirectory=/root/projects/couchlist
# Absolute node path — don't rely on $PATH at boot.
ExecStart=/usr/bin/node /root/projects/couchlist/server.js
# NODE_ENV=production tells express to skip dev-only logging.
Environment=NODE_ENV=production
# server.js reads process.env.PORT.
Environment=PORT=3000

# Restart behavior — if node crashes, come back up in 10 seconds.
Restart=always
RestartSec=10
# No throttle during early days — if it flaps, journalctl will show why.
StartLimitIntervalSec=0

# Send stdout/stderr to the systemd journal so journalctl captures them.
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
